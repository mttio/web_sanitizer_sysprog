{
  "html": {
    "allow_scripts": [],
    "allow_origins": [
      "trusted.com"
    ],
    "strip_event_handlers": true,
    "rewrite_dangerous_uris": true
  },
  "urls": {
    "dangerous_domains": [
      "malicious-domain.com",
      "evil.com"
    ],
    "dangerous_domain_action": "warn_and_replace",
    "idn_action": "deny"
  },
  "resources": {
    "fetch_sub_resources": true,
    "max_depth": 1,
    "max_bytes": 1048576,
    "max_requests": 5
  }
}