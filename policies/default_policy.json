{
  "html": {
    "allow_scripts": [],
    "allow_origins": ["trusted.com"],
    "strip_event_handlers": true,
    "rewrite_dangerous_uris": true
  },
  "urls": {
    "block_list": ["malicious-domain.com", "evil.com"],
    "rewrite_suspicious": true,
    "allow_idn": false
  },
  "resources": {
    "fetch_sub_resources": true,
    "max_depth": 1,
    "max_bytes": 1048576,
    "max_requests": 5
  }
}
