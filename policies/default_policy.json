{
  "html": {
    "allow_scripts": [],
    "allow_origins": [
      "trusted.com"
    ],
    "strip_event_handlers": true,
    "rewrite_dangerous_uris": true,
    "dangerous_domain_action": "replace"
  },
  "urls": {
    "dangerous_domains": [
      "malicious-domain.com",
      "evil.com",
      "iana.org",
      "developers.google.com",
      "com.google.android.youtube"
    ],
    "idn_action": "warn"
  },
  "resources": {
    "fetch_sub_resources": true,
    "max_depth": 10,
    "max_bytes": 204800,
    "max_bytes_action": "warn",
    "max_requests": 10
  },
  "connections": {
    "connection_timeout": "3s",
    "overall_timeout": "15s",
    "max_redirects": 10,
    "max_redirects_action": "warn",
    "user_agent": "CoolBot/0.0 (https://example.org/coolbot/; coolbot@example.org) generic-library/0.0",
    "dangerous_domain_action": "warn"
  }
}